# Laravel Docker Template - Production Environment Variables
# Copy this to .env.prod and customize for your server deployment

# ============================================
# Project Configuration
# ============================================
PROJECT_NAME="blog"
APP_NAME="blog"

# ============================================
# Application
# ============================================
APP_PORT=5069
APP_URL=http://gheith.me
APP_KEY=base64:your-generated-key-here
APP_ENV=production
APP_DEBUG=false

# ============================================
# Logging
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ============================================
# Database - PostgreSQL
# ============================================
DB_DATABASE=blog
DB_USERNAME=blog_user
DB_PASSWORD=blog_secure_db_password

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=blog_secure_redis_password

# ============================================
# GitHub Container Registry
# ============================================
GITHUB_USERNAME=gheith3
IMAGE_NAME=blog

# ============================================
# Deployment
# ============================================
RUN_MIGRATIONS=false

# Optional: Custom data path for volumes
# DATA_PATH=/opt/docker-data
